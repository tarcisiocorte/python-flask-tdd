# Copy this file to .env for local development.
# Replace placeholder values before running shared environments or deployments.

FLASK_ENV=development
PORT=5000
JWT_SECRET=replace-with-a-long-random-value
BCRYPT_SALT=12

POSTGRES_USER=flask_user
POSTGRES_PASSWORD=replace-with-a-local-postgres-password
POSTGRES_DB=flask_db
POSTGRES_PORT=5432

MONGO_USER=flask_user
MONGO_PASSWORD=replace-with-a-local-mongo-password
MONGO_DB_NAME=flask_db
MONGO_PORT=27017
MONGO_URL=mongodb://flask_user:replace-with-a-local-mongo-password@localhost:27017/?authSource=admin
